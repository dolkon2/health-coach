{
  "expo": {
    "name": "health-coach",
    "slug": "health-coach",
    "scheme": "healthcoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dylan.healthcoachproject"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "usdaApiKey": "3k16veE4wrwgFVX09MuiByrijHX1jfVmQG1QA33w"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-sqlite",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "This app reads your steps, sleep, and workouts so your timeline reflects what actually happened. Your data is never written back or shared.",
          "background": false
        }
      ]
    ]
  }
}
