# Copy this file to `.env.local` (gitignored) and fill in real values for local dev.
# For EAS cloud builds, set these as EAS environment variables instead.

# Anthropic API key — optional; enables the LLM food parser. Unset = regex fallback.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# USDA FoodData Central key — free at fdc.nal.usda.gov. Unset = public DEMO_KEY.
EXPO_PUBLIC_USDA_API_KEY=
