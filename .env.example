# Copy this file to `.env.local` (gitignored) and fill in real values for local dev.
# For EAS cloud builds, set these as EAS environment variables instead.

# Anthropic API key — optional; enables the LLM food parser. Unset = regex fallback.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# USDA FoodData Central key — free at fdc.nal.usda.gov. Unset = public DEMO_KEY.
EXPO_PUBLIC_USDA_API_KEY=

# MapTiler — vector tiles for the GPS route map. Unset = the route falls back to
# the SVG trace (no map, nothing fabricated). Free key at maptiler.com.
EXPO_PUBLIC_MAPTILER_KEY=
# MapTiler style id for the route map. Unset defaults to `outdoor`.
EXPO_PUBLIC_MAP_STYLE_ID=

# Synoptic/MesoWest — free tier (5k req/mo, register at synopticdata.com) for
# F2's broader live-observation station coverage. Unset = the Forecast
# dashboard's live reading falls back to NWS-only (still works, fewer stations).
EXPO_PUBLIC_SYNOPTIC_TOKEN=

# Stadia Maps — hosts the Valhalla routing engine for the route builder's
# snap-to-trail. Free non-commercial tier (200k credits/mo) at stadiamaps.com.
# Unset = the builder degrades to free-line (straight segments), never blocked.
EXPO_PUBLIC_STADIA_API_KEY=
# Self-hosted / custom Valhalla base URL (e.g. http://localhost:8002). Set this
# to move off Stadia (paid commercial launch or your own server) with no code
# change — the single routing swap point. Unset = Stadia's hosted endpoint.
EXPO_PUBLIC_ROUTING_URL=
# Overpass API endpoint for the river snap-to-waterway clip. Unset defaults to
# the public instance (https://overpass-api.de/api/interpreter); keyless.
EXPO_PUBLIC_OVERPASS_URL=
